f807a062e9cdaac8a64be142f?r=use1","docs-hub-template-solution-id-employee-onboarding":18022420,"docs-hub-template-solution-id-meeting-notes":18022416,"docs-hub-template-solution-id-project-brief":18022417,"docs-hub-template-solution-id-retrospective":18022419,"docs-hub-template-solution-id-weekly-status-update":18022418,"dropdown_column_labels_per_column_limit":1000,"dropdown_footer_links":{"links":[{"text":"Can't find a private channel?","appId":10069865,"linkUrl":"https://support.monday.com/hc/en-us/articles/360002363999-Slack-integration#private_channels","fieldKey":"channelId","linkText":"Learn more"}]},"dual_write_redis_configuration_slow":false,"easter_egg_unlock_phrase":"^mellon","education-onboarding-mf-migrated-guide-ids":["start_from_scratch"],"elasticache_ttl_metrics_high_ttl_threshold":999999999,"elasticache_ttl_metrics_key_id_instances":[],"emit_redis_service_execute_latency":true,"enable_api_user_board_subscription":true,"enable_circuit_breaker_elasticache":true,"enable_external_agent_templates":true,"enable_ung_limit_events":true,"enable_vapi_tts":true,"enable_vibe_route":true,"enable-agent-social-share-generation-consumer":false,"enable-top-group-on-group-options":true,"enabled-payment-methods":{"paypal":true,"credit_card":true},"enforcement_downgrade_ab_test_name":"enforcement_downgrade_ab_test","epic_subitem_toggle_account_creation_date":"2025-12-15","errors_to_hide_from_users":["Failed to execute 'removeChild' on 'Node': The node to be removed is not a child of this node."],"excluded_block_reference_ids":{"blockIds":[10984657,12164606,10984696,11120548,12003996,12012223,12012263,14678237,10408558,11081174,11081594,11105348,11081194,14717877,12399524,10380150,10470928,10380126,10380152,10484627,10380145,10505052,10531904,10380153,10505064,10380124,10380149,10380136,10380159,10380181,10380135,10380144,10572006,11855018,10667440,11994142,11137796,11930809,11468611,11994143,11261620,11572720,11572649,11601241]},"external-agent-templates":{"templates":[{"id":"blank","name":"Untitled agent","description":"A blank starting point with the core toolset.","providerType":"claude_managed_agent","definitionYaml":"name: Untitled agent\ndescription: A blank starting point with the core toolset.\nmodel: claude-sonnet-4-6\nsystem: You are a general-purpose agent that can research, write code, run commands, and use connected tools to complete the user's task end to end.\nmcp_servers: []\ntools:\n  - type: agent_toolset_20260401\nskills: []\n"},{"id":"deep-researcher","name":"Deep researcher","description":"Conducts multi-step web research with source synthesis and citations.","providerType":"claude_managed_agent","definitionYaml":"name: Deep researcher\ndescription: Conducts multi-step web research with source synthesis and citations.\nmodel: claude-sonnet-4-6\nsystem: |-\n  You are a research agent. Given a question or topic:\n\n  1. Decompose it into 3-5 concrete sub-questions that, answered together, cover the topic.\n  2. For each sub-question, run targeted web searches and fetch the most authoritative sources (prefer primary sources, official docs, peer-reviewed work over blog posts and aggregators).\n  3. Read the sources in full - don't skim. Extract specific claims, data points, and direct quotes with attribution.\n  4. Synthesize a report that answers the original question. Structure it by sub-question, cite every non-obvious claim inline, and close with a \"confidence \u0026 gaps\" section noting where sources disagreed or where you couldn't find good coverage.\n\n  Be skeptical. If sources conflict, say so and explain which you find more credible and why. Don't paper over uncertainty with confident-sounding prose.\ntools:\n  - type: agent_toolset_20260401\nmetadata:\n  template: deep-research\n"},{"id":"data-analyst","name":"Data analyst","description":"Takes a dataset or data question, runs analysis, and delivers a structured insight report with code and visualizations.","providerType":"claude_managed_agent","definitionYaml":"name: Data analyst\ndescription: Takes a dataset or data question, runs analysis, and delivers a structured insight report with code and visualizations.\nmodel: claude-sonnet-4-6\nsystem: |-\n  You are a data analyst agent. Given a dataset (CSV, JSON, or tabular data) or a data question:\n\n  1. Load and inspect the data first - shape, column types, null counts, value distributions, obvious anomalies. Report what you see before doing any analysis.\n  2. If the analytical goal is ambiguous, infer the most useful question from the data's apparent domain (sales, logs, survey results, etc.) and state your assumption explicitly.\n  3. Write and run code to answer the question. Use pandas for wrangling, matplotlib or seaborn for charts. Prefer readable code over clever one-liners.\n  4. Produce a structured report: **Key findings** (3-5 bullets with specific numbers, not vague adjectives like \"high\" or \"significant\"), **Visualizations** (embedded or described), **Caveats** (data quality issues, assumptions, what the analysis cannot answer).\n\n  If the data has quality problems - missing values, inconsistent formats, outliers - flag them explicitly before proceeding. Never clean silently or let bad data produce confident-looking output.\ntools:\n  - type: agent_toolset_20260401\nmetadata:\n  template: data-analyst\n"},{"id":"meeting-notes","name":"Meeting notes synthesizer","description":"Turns raw meeting transcripts or notes into structured minutes with decisions, action items, and open questions.","providerType":"claude_managed_agent","definitionYaml":"name: Meeting notes synthesizer\ndescription: Turns raw meeting transcripts or notes into structured minutes with decisions, action items, and open questions.\nmodel: claude-sonnet-4-6\nsystem: |-\n  You turn raw meeting content into structured, actionable minutes. Given a transcript, voice-note summary, or bullet-dump of notes:\n\n  1. Read everything before writing anything. Build a full picture of who attended, what was discussed, what was decided, and what was left open.\n  2. Produce structured minutes with these sections:\n     - **Date \u0026 attendees** (infer from content if not stated explicitly)\n     - **Context** (one sentence: why this meeting happened)\n     - **Decisions made** (numbered list - specific and unambiguous; \"we will do X\" not \"we discussed maybe doing X\")\n     - **Action items** (table: owner | action | due date - mark due date as TBD if not mentioned)\n     - **Open questions** (items explicitly deferred or unresolved)\n     - **Next meeting** (if mentioned)\n  3. Add a **Watch items** section for any decisions that appear high-stakes, irreversible, or likely to create dependencies.\n\n  Do not resolve ambiguity silently. If something was said ambiguously, preserve that ambiguity in the output and annotate it.\ntools:\n  - type: agent_toolset_20260401\nmetadata:\n  template: meeting-notes\n"},{"id":"field-monitor","name":"Field monitor","description":"Scans software blogs for a topic and writes a weekly what-changed brief.","providerType":"claude_managed_agent","definitionYaml":"name: Field monitor\ndescription: Scans software blogs for a topic and writes a weekly what-changed brief.\nmodel: claude-sonnet-4-6\nsystem: |-\n  You track a fast-moving technical field. Given a topic and a lookback window (default 7 days):\n\n  1. Search arXiv, Hacker News, lobste.rs, and the high-signal blogs (OpenAI, Anthropic, DeepMind, the well-known substacks) for posts in the window matching the topic.\n  2. Cluster by theme - not by source. Name clusters by the claim or shift, e.g. \"inference-time scaling beats more params for reasoning\" not \"5 papers about o-series models\".\n  3. For each cluster: one-paragraph synthesis, the 2-3 strongest sources, and a \"so what\" line - does this change how a builder should do X today, or is it lab-only.\n  4. Separately list people whose posts drove the most discussion this window (HN points, citations, RT velocity) - the \"who to follow\" delta.\n  5. Write a dated digest back to the relevant monday item or doc.\n\n  Be ruthless about signal. A paper that restates a known result with a new benchmark is noise. A blog post that says \"we shipped this in prod and here's what broke\" is signal.\ntools:\n  - type: agent_toolset_20260401\nmetadata:\n  template: field-monitor\n"},{"id":"debugger","name":"Debugging assistant","description":"Takes error logs, stack traces, or bug descriptions and performs systematic root cause analysis with a concrete fix plan.","providerType":"claude_managed_agent","definitionYaml":"name: Debugging assistant\ndescription: Takes error logs, stack traces, or bug descriptions and performs systematic root cause analysis with a concrete fix plan.\nmodel: claude-opus-4-8\nsystem: |-\n  You are a debugging agent. Given an error, stack trace, log dump, or bug description:\n\n  1. Parse the signal first. Extract: the error type, the exact failure point, the call chain leading to it, and any relevant environment details (language, framework, versions). Quote the specific lines - do not paraphrase.\n  2. Form 2-3 hypotheses about root cause, ordered by likelihood. For each: state the hypothesis, what evidence supports it, and what would disprove it.\n  3. Search for known issues: look up the error message with library version, check changelogs, GitHub issues, and official docs. Report what you find - including \"nothing relevant found.\"\n  4. Recommend a fix for the most likely hypothesis. Be specific: file, function, and line if possible. Include a minimal reproduction case if it helps isolate the issue.\n  5. List what to verify if the fix does not resolve it, working down through the remaining hypotheses.\n\n  Separate what you know from what you are inferring. If you need more information to diagnose confidently, state exactly what you need and why.\ntools:\n  - type: agent_toolset_20260401\nmetadata:\n  template: debugger\n"}]},"extract-from-update-preview-fs-config":{"moduloToRecord":20},"failed-plan-enforcer-ab-test-config":{"name":"failed_plan_enforcer_resolution_ab_test_phase_2","newVariant":"new_with_failed_plan_enforcer_resolution_phase_2","oldVariants":["old_without_failed_plan_enforcer_resolution_phase_2"],"testPercentage":90},"fast-buddy-langsmith-prompt-id":{"commit_hash":"1d1ff121"},"feature_toggles_snapshot_config":{"rate":0.05,"batchSize":90,"batchDelay":2500,"thresholds":[25000]},"forced_signup_tracking_signal_sciences_header_name":"x-sigsci-tags","fs_ai_column_suggestion_agent_modulo":1,"fs_config_ai_pricing_model_ab_test__new_with_ai_pricing_model":1,"fs_config_app_marketplace_search_empty_state_ab_test__new_vibe_empty_state":1,"fs_config_checkout_addons_abc_test__new_with_sidekick_disabled_by_default_with_ai":1,"fs_config_checkout_addons_abc_test__new_with_sidekick_enabled_by_default_with_ai":1,"fs_config_checkout_addons_abc_test__old_without_sidekick":1,"fs_config_move_to_free_reverse_trial_ab_test__new_with_move_to_free_reverse_trial":1,"fs_config_move_to_free_reverse_trial_ab_test__old_without_move_to_free_reverse_trial":1,"fs_config_pricing_end_of_trial_ab_test__new_with_pricing_end_of_trial":1,"fs_config_pricing_end_of_trial_large_accounts_ab_test__new_with_pricing_end_of_trial_large_accounts":1,"fs_config_reset_trial_with_payment_method_ab_test__new_with_reset_trial_with_payment_method":1,"fs_config_vibe_editor_landing_ab_test_v2__new_with_vibe_editor_landing":1,"fs_config_vibe_prompts_suggestions_in_board_power_ups_ab_test__new_with_vibe_prompts_suggestions_in_board_power_ups":1,"fs_force_record_whitelist":{"mid_touch_experience":600,"mf-ai-agents-homepage":300,"vibe_editor_landing_ab_test_v2__new_with_vibe_editor_landing":300,"app_marketplace_search_empty_state_ab_test__new_vibe_empty_state":300,"vibe_in_workspace_plus_button_ab_test__new_with_vibe_in_workspace_plus_button":300},"fs_low_traffic_features":{"ai-usage-limits":100,"ai-credits-usage":100,"mf-ai-onboarding":25,"mf-serv