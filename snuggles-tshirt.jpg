],"confirmation_supported_addons":{},"connection_app_categories":{"Box":["Files"],"Hex":["Analytics"],"Clay":["Sales"],"Zoom":["Popular","Meetings"],"Gmail":["Popular","Communication"],"Slack":["Popular","Communication"],"Claude":[],"Cursor":["Development"],"GitHub":["Popular","Development"],"GitLab":["Development"],"ChatGPT":["Popular"],"Dropbox":["Files"],"HubSpot":["Sales"],"JotForm":["Forms"],"Outlook":["Popular","Communication"],"DocuSign":["Sales","Finance"],"Intercom":["Support"],"MS Teams":["Communication"],"OneDrive":["Files"],"Power BI":["Analytics"],"ZoomInfo":["Sales"],"Amazon S3":["Files"],"Freshdesk":["Support"],"Snowflake":["Analytics"],"Confluence":["Development"],"Databricks":["Development","Analytics"],"Jira Cloud":["Popular","Development"],"QuickBooks":["Finance"],"Salesforce":["Popular","Sales"],"SharePoint":["Files"],"Google Chat":["Communication"],"Google Drive":["Popular","Files"],"Google Calendar":["Popular","Meetings"],"Jira Data Center":["Development"],"Outlook Calendar":["Popular","Meetings"],"Copper Integration":["Sales"],"Resend Integration":["Communication"],"Stripe Integration":["Sales","Finance"],"Twilio Integration":["Communication"],"Calendly Integration":["Meetings"],"Typeform Integration":["Forms"],"Bitbucket Integration":["Development"],"PagerDuty Integration":["Support","Development"],"Pipedrive Integration":["Sales"],"Eventbrite Integration":["Meetings"]},"connection_app_descriptions":{"Box":"Access Box files directly from monday.com.","Hex":"Share analytics and reports from Hex.","Clay":"Enrich and sync contact data with monday.com.","Miro":"Connect Miro boards to items in monday.com.","Zoom":"Create Zoom meetings directly from monday.com items.","Asana":"Keep Asana tasks connected to your work.","Canva":"Attach Canva designs to items in monday.com.","Figma":"Connect Figma files to related work in monday.com.","Gmail":"Connect emails to items automatically and track conversations.","Slack":"Get instant updates and turn monday activity into messages.","Claude":"Use AI to analyze and draft content.","Cursor":"Connect Cursor to sync code updates and track development work in monday.com","FigJam":"Link FigJam boards to related work.","GitHub":"Keep GitHub issues and pull requests visible.","GitLab":"Track GitLab issues and changes in monday.com.","Notion":"Bring Notion pages and databases into monday.com.","Trello":"Bring Trello cards into monday.com.","AutoCAD":"Attach AutoCAD files to related work.","ChatGPT":"Generate and summarize content in monday.com.","Dropbox":"Access and attach Dropbox files to your work.","HubSpot":"Keep HubSpot contacts and deals connected to your work.","JotForm":"Turn form submissions into actionable work.","Outlook":"Connect emails to items and track conversations in monday.com.","DocuSign":"Track agreements and signature status.","Intercom":"Turn customer conversations into trackable work.","OneDrive":"Attach and work with OneDrive files inside monday.com.","Power BI":"View and connect Power BI reports.","ZoomInfo":"Enrich leads and company details inside monday.com.","Amazon S3":"Attach files stored in S3 to your work.","Freshdesk":"Keep support tickets connected to your work.","Snowflake":"Bring selected Snowflake data into monday.com.","Confluence":"Link documentation to related work in monday.com.","Databricks":"Track Databricks jobs and updates.","Jira Cloud":"Track Jira issues and updates alongside your work.","QuickBooks":"Sync invoices and financial updates.","Salesforce":"Keep Salesforce records aligned with your work.","SharePoint":"Access and attach SharePoint files to items.","Smartsheet":"Reflect Smartsheet rows and updates.","Google Chat":"Send monday.com updates directly to Google Chat.","Google Drive":"Attach and manage Google Drive files in items.","Microsoft Team":"Receive updates and notifications inside Microsoft Teams.","Google Calendar":"Create and update calendar events from items.","Active Directory":"Sync user information with your account.","Jira Data Center":"Align development work and business teams.","Outlook Calendar":"Sync meetings with items to keep schedules aligned.","Toggl Integration":"Sync time tracking updates with your work.","Copper Integration":"Keep CRM contacts and deals aligned with monday.com.","Resend Integration":"Send automated emails directly from monday.com workflows.","Stripe Integration":"Track payments and transaction updates.","Twilio Integration":"Send SMS notifications from workflows to your contacts.","Harvest Integration":"Track time entries from Harvest.","Todoist Integration":"Turn Todoist tasks into actionable items.","Basecamp Integration":"Track Basecamp tasks and updates.","Calendly Integration":"Turn booked meetings into trackable work in monday.com.","Typeform Integration":"Create items automatically from new responses.","Bitbucket Integration":"Track Bitbucket issues and updates.","PagerDuty Integration":"Create items automatically when incidents occur.","Pipedrive Integration":"Track Pipedrive deals and activities in monday.com.","Eventbrite Integration":"Track event registrations and updates in monday.com."},"consumption_limits":{"crm":{"pro":{"dashboard":50,"board_column":75,"quotes_and_invoices":250},"basic":{"dashboard":1,"board_column":5,"quotes_and_invoices":20},"standard":{"dashboard":5,"board_column":15,"quotes_and_invoices":50},"enterprise":{"dashboard":null,"board_column":null,"quotes_and_invoices":null}}},"consumption_min_created_at":"2025-11-02T11:37:47.156Z","consumption_reporting_excluded_accounts":{"accountIds":[5]},"consumption_resources_start_dates":{"dashboard":"2025-11-02T11:37:47.156Z","board_column":"2025-11-02T11:37:47.156Z","quotes_and_invoices":"2025-12-14T10:30:47.156Z"},"consumption_resources_start_dates_internal_products":{"quotes_and_invoices":"2026-11-23T11:37:47.156Z"},"contact_sync_onboarding_cutoff_date":"2026-03-22T09:00:00Z","contact-sales-hubspot-en-form-id":"dc710b2f-3516-4251-9414-7e8f82580217","content-management-cac